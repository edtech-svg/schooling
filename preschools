      "source": [
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Map 'na' to 'Privately-Funded' for better clarity in the analysis\n",
        "df['scheme_type_labeled'] = df['scheme_type'].fillna('Privately-Funded')\n",
        "df['scheme_type_labeled'] = df['scheme_type_labeled'].replace('na', 'Privately-Funded')\n",
        "\n",
        "# Create a pivot table/crosstab for the distribution\n",
        "dist_df = pd.crosstab(df['service_model'], df['scheme_type_labeled']).reset_index()\n",
        "\n",
        "# Melting the dataframe for easier plotting\n",
        "dist_melted = dist_df.melt(id_vars='service_model', var_name='Funding Model', value_name='Count')\n",
        "\n",
        "# Plotting the grouped bar chart\n",
        "plt.figure(figsize=(12, 7))\n",
        "sns.barplot(x='service_model', y='Count', hue='Funding Model', data=dist_melted, palette='viridis')\n",
        "\n",
        "plt.title('Distribution of Centres by Service Model and Funding Model')\n",
        "plt.xlabel('Service Model')\n",
        "plt.ylabel('Number of Centres')\n",
        "plt.legend(title='Funding Model', bbox_to_anchor=(1.05, 1), loc='upper left')\n",
        "plt.grid(axis='y', linestyle='--', alpha=0.6)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Display the raw counts\n",
        "display(dist_df)"
      ],
