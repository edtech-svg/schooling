      },
      "source": [
        "levels = ['infant', 'pg', 'n1', 'n2', 'k1', 'k2']\n",
        "months = ['current_month', 'next_month', 'third_month', 'fourth_month', 'fifth_month', 'sixth_month', 'seventh_month']\n",
        "\n",
        "vacancy_trends = {}\n",
        "for lvl in levels:\n",
        "    cols = [f'{lvl}_vacancy_{m}' for m in months]\n",
        "    vacancy_trends[lvl] = df[cols].mean().values\n",
        "\n",
        "trends_df = pd.DataFrame(vacancy_trends, index=months)\n",
        "\n",
        "trends_df.plot(figsize=(12, 6), marker='o')\n",
        "plt.title('Average Availability (1=Available, 0=Full) across Levels over 7 Months')\n",
        "plt.ylabel('Average Availability Score')\n",
        "plt.xlabel('Timeline')\n",
        "plt.grid(True)\n",
        "plt.show()"
