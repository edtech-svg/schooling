      "source": [
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# Restoring the correct dataset since 'df' was overwritten\n",
        "DATASET_ID = \"d_696c994c50745b079b3684f0e90ffc53\"\n",
        "df = download_file(DATASET_ID)\n",
        "\n",
        "# Re-apply cleaning steps to the restored dataframe\n",
        "vacancy_columns = [col for col in df.columns if 'vacancy' in col]\n",
        "replacement_map = {'na': np.nan, 'Not Applicable': np.nan, 'Full': 0, 'Available': 1}\n",
        "for col in vacancy_columns:\n",
        "    df[col] = df[col].replace(replacement_map)\n",
        "    df[col] = pd.to_numeric(df[col], errors='coerce')\n",
        "df['service_model'] = df['service_model'].replace('na', np.nan)\n",
        "\n",
        "# Prepare data for the bar chart\n",
        "service_model_counts = df['service_model'].value_counts().reset_index()\n",
        "service_model_counts.columns = ['Service Model', 'Count']\n",
