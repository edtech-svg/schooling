      },
      "source": [
        "import numpy as np\n",
        "import pandas as pd # Ensure pandas is imported if not already\n",
        "\n",
        "# Identify all vacancy-related columns\n",
        "vacancy_columns = [col for col in df.columns if 'vacancy' in col]\n",
        "\n",
        "# Define the mapping for replacement\n",
        "replacement_map = {'na': np.nan, 'Not Applicable': np.nan, 'Full': 0, 'Available': 1}\n",
        "\n",
        "for col in vacancy_columns:\n",
        "    # First, apply the replacements\n",
        "    df[col] = df[col].replace(replacement_map)\n",
        "    # Then, convert to numeric, coercing any remaining errors to NaN\n",
        "    df[col] = pd.to_numeric(df[col], errors='coerce')\n",
        "\n",
        "# Convert 'last_updated' to datetime\n",
        "df['last_updated'] = pd.to_datetime(df['last_updated'])\n",
        "\n",
        "# Replace 'na' in 'service_model' and 'scheme_type' with NaN (as seen in value_counts)\n",
        "df['service_model'] = df['service_model'].replace('na', np.nan)\n",
        "df['scheme_type'] = df['scheme_type'].replace('na', np.nan)\n",
        "\n",
        "print(\"Data types after cleaning:\")\n",
        "df.info()"
      ],
